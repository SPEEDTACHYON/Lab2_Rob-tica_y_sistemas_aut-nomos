
//Librerías

#include <webots/robot.h>
#include <webots/distance_sensor.h>
#include <webots/position_sensor.h>
#include <webots/motor.h>
#include <stdio.h>
#include <math.h>

//Constantes

#define TIME_STEP 16
#define R_RUEDA 0.021
#define DISTANCIA_RUEDAS 0.052
#define N_PROMEDIO 4
#define MAX_VELOCITY 6.28
#define RANGO_SENSOR 0.05
#define DISTANCIA_MAXIMA 1.414
#define DISTANCIA_MINIMA 0.05
#define UMBRAL_SEGURIDAD 0.15 // El robot frenará si Kalman estima menos de 15 cm
#define ESTADO_AVANZANDO 0
#define ESTADO_GIRANDO 1

// Inicio del main

int main(int argc, char **argv) {
    wb_robot_init();

    FILE *log_file = fopen("datos_lab2_final.csv", "w");
    if (log_file != NULL) {
        fprintf(log_file, "Tiempo_s,Sensor_Crudo_m,Distancia_Kalman_m,Posicion_X,Posicion_Y\n");
    }

	//Inicialización de sensores

    WbDeviceTag ps0 = wb_robot_get_device("ps0"); 
    WbDeviceTag ps7 = wb_robot_get_device("ps7"); 
    WbDeviceTag ps2 = wb_robot_get_device("ps2"); 
    WbDeviceTag ps5 = wb_robot_get_device("ps5"); 
    wb_distance_sensor_enable(ps0, TIME_STEP);
    wb_distance_sensor_enable(ps7, TIME_STEP);
    wb_distance_sensor_enable(ps2, TIME_STEP);
    wb_distance_sensor_enable(ps5, TIME_STEP);

    WbDeviceTag enc_izq = wb_robot_get_device("left wheel sensor");
    WbDeviceTag enc_der = wb_robot_get_device("right wheel sensor");
    wb_position_sensor_enable(enc_izq, TIME_STEP);
    wb_position_sensor_enable(enc_der, TIME_STEP);

    WbDeviceTag mot_izq = wb_robot_get_device("left wheel motor");
    WbDeviceTag mot_der = wb_robot_get_device("right wheel motor");
    wb_motor_set_position(mot_izq, INFINITY);
    wb_motor_set_position(mot_der, INFINITY);

    double pos_ant_izq = 0.0, pos_ant_der = 0.0, x_pos = 0.0, y_pos = 0.0, theta = 0.0;
    double buffer[N_PROMEDIO] = {0.0};
    int idx = 0, estado = ESTADO_AVANZANDO, temp_giro = 0, dir_giro = 1;
    double d_tongo = 1.0, P = 0.5, Q = 0.005;

	//Inicialización del movimiento del robot y valores crudos

    while (wb_robot_step(TIME_STEP) != -1) {
        double pos_act_izq = wb_position_sensor_get_value(enc_izq);
        double pos_act_der = wb_position_sensor_get_value(enc_der);

        double ds_izq = R_RUEDA * (pos_act_izq - pos_ant_izq);
        double ds_der = R_RUEDA * (pos_act_der - pos_ant_der);
        double ds = (ds_izq + ds_der) / 2.0;
        theta += (ds_der - ds_izq) / DISTANCIA_RUEDAS;
        x_pos += ds * cos(theta);
        y_pos += ds * sin(theta);
        pos_ant_izq = pos_act_izq; pos_ant_der = pos_act_der;

        double max_cruda = fmax(wb_distance_sensor_get_value(ps0), wb_distance_sensor_get_value(ps7));
        double z_metrica = RANGO_SENSOR * (1.0 - (max_cruda / 4095.0));
        if (z_metrica < 0) z_metrica = 0;

        // Filtros simples (Hard thresholding y promedio móvil suavizado)

        double z_validada = (z_metrica >= DISTANCIA_MINIMA && z_metrica <= DISTANCIA_MAXIMA) ? z_metrica : d_tongo;
        double R = (z_validada == z_metrica) ? 0.02 : 1000.0;

        buffer[idx] = z_validada;
        idx = (idx + 1) % N_PROMEDIO;
        double z_k = (buffer[0] + buffer[1] + buffer[2] + buffer[3]) / 4.0;

        // Actualización de Kalman

        double d_pred = (estado == ESTADO_AVANZANDO) ? (d_tongo - ds) : d_tongo;
        double K = (P + Q) / (P + Q + R);
        d_tongo = d_pred + K * (z_k - d_pred);
        P = (1.0 - K) * (P + Q);

        // Navegación reactiva

        if (estado == ESTADO_AVANZANDO) {

            // Frenamos antes : Si el filtro de Kalman indica distancia menor a 15cm, esquivamos el obstáculo.

            if (d_tongo < UMBRAL_SEGURIDAD) {
                dir_giro = (wb_distance_sensor_get_value(ps5) > wb_distance_sensor_get_value(ps2)) ? 1 : -1;
                estado = ESTADO_GIRANDO;
                temp_giro = 28; 
                printf("[EVASIÓN] Dist: %.3fm | Coord: (%.2f, %.2f)\n", d_tongo, x_pos, y_pos);
            } else {
                wb_motor_set_velocity(mot_izq, MAX_VELOCITY);
                wb_motor_set_velocity(mot_der, MAX_VELOCITY);
            }
        } else {
            wb_motor_set_velocity(mot_izq, MAX_VELOCITY * dir_giro);
            wb_motor_set_velocity(mot_der, -MAX_VELOCITY * dir_giro);
            if (--temp_giro <= 0) estado = ESTADO_AVANZANDO;
        }
    }
    wb_robot_cleanup();
    return 0;
}

